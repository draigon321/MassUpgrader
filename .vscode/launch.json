{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Vite: One-Click Edge Debug (F5)",
      "type": "msedge",
      "request": "launch",
      "preLaunchTask": "vite:dev-debug",
      "url": "http://localhost:5173/",
      "userDataDir": true,
      "webRoot": "${workspaceFolder}/src"
    },
    {
      "name": "Vite: One-Click Chrome Debug",
      "type": "chrome",
      "request": "launch",
      "preLaunchTask": "vite:dev-debug",
      "url": "http://localhost:5173/",
      "userDataDir": true,
      "webRoot": "${workspaceFolder}/src"
    },
    {
      "name": "Vite: Run + Open Browser",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev:host",
      "serverReadyAction": {
        "pattern": "Local:\\s+http://localhost:(\\d+)/",
        "uriFormat": "http://localhost:%s",
        "action": "openExternally"
      }
    },
    {
      "name": "Vite: Run + Open Browser (Chrome)",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev:host",
      "serverReadyAction": {
        "pattern": "Local:\\s+http://localhost:(\\d+)/",
        "uriFormat": "http://localhost:%s",
        "action": "openExternally"
      }
    },
    {
      "name": "Vite: Start Dev Server Only",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev:debug"
    },
    {
      "name": "Vite: Debug Edge (Manual)",
      "type": "msedge",
      "request": "launch",
      "url": "http://localhost:5173/",
      "userDataDir": true,
      "webRoot": "${workspaceFolder}/src"
    },
    {
      "name": "Vite: Debug Chrome (Manual)",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5173/",
      "userDataDir": true,
      "webRoot": "${workspaceFolder}/src"
    }
  ]
}